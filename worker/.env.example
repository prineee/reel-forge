# Supabase — use the base project URL, not the /auth/v1/... path
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Pexels
PEXELS_API_KEY=your-pexels-api-key

# Cloudinary — format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://123456:abcdef@mycloud

# Server
PORT=3001

# FFmpeg paths — set automatically in Docker via ENV; leave blank to use @ffmpeg-installer binaries (local dev)
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
